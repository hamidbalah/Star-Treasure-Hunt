/* ============================================
   🎨 الإعدادات العامة
   ============================================ */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

:root {
    --primary-color: #667eea;
    --secondary-color: #764ba2;
    --success-color: #2ecc71;
    --danger-color: #e74c3c;
    --warning-color: #f39c12;
    --dark-color: #2c3e50;
    --light-color: #ecf0f1;
}

body {
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    background: linear-gradient(135deg, var(--primary-color) 0%, var(--secondary-color) 100%);
    overflow: hidden;
    height: 100vh;
    margin: 0;
    color: #333;
}

/* ============================================
   📺 الشاشات
   ============================================ */
.screen {
    display: none;
    width: 100%;
    height: 100vh;
    justify-content: center;
    align-items: center;
    position: fixed;
    top: 0;
    left: 0;
}

.screen.active {
    display: flex;
}

.screen.overlay {
    background: rgba(0, 0, 0, 0.85);
    z-index: 100;
    backdrop-filter: blur(10px);
}

/* ============================================
   🌟 شاشة التحميل
   ============================================ */
.loading-content {
    text-align: center;
    animation: fadeIn 1s ease;
}

.game-title {
    font-size: 4em;
    color: white;
    text-shadow: 0 0 20px rgba(255, 255, 255, 0.5);
    margin-bottom: 40px;
    animation: pulse 2s ease infinite;
}

.loading-bar {
    width: 400px;
    height: 30px;
    background: rgba(255, 255, 255, 0.2);
    border-radius: 15px;
    overflow: hidden;
    margin: 20px auto;
    border: 2px solid rgba(255, 255, 255, 0.3);
}

.loading-fill {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, #2ecc71, #27ae60);
    border-radius: 15px;
    animation: loading 2s ease forwards;
    box-shadow: 0 0 20px rgba(46, 204, 113, 0.5);
}

.loading-text {
    color: white;
    font-size: 1.5em;
    margin-top: 20px;
    animation: blink 1.5s ease infinite;
}

@keyframes loading {
    to { width: 100%; }
}

@keyframes fadeIn {
    from { opacity: 0; transform: translateY(-20px); }
    to { opacity: 1; transform: translateY(0); }
}

@keyframes pulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.05); }
}

@keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
}

/* ============================================
   📋 القوائم
   ============================================ */
.menu-container {
    background: rgba(255, 255, 255, 0.98);
    padding: 50px;
    border-radius: 25px;
    box-shadow: 0 25px 80px rgba(0, 0, 0, 0.4);
    text-align: center;
    max-width: 600px;
    width: 90%;
    animation: slideUp 0.6s ease;
    max-height: 90vh;
    overflow-y: auto;
}

.pause-menu, .result-menu {
    max-width: 500px;
}

@keyframes slideUp {
    from {
        transform: translateY(50px);
        opacity: 0;
    }
    to {
        transform: translateY(0);
        opacity: 1;
    }
}

.animated-title {
    font-size: 3.5em;
    background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 15px;
    animation: gradient 3s ease infinite;
    background-size: 200% 200%;
}

@keyframes gradient {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
}

.subtitle {
    font-size: 1.4em;
    color: #666;
    margin-bottom: 40px;
    font-weight: 500;
}

h2 {
    font-size: 2.5em;
    color: var(--primary-color);
    margin-bottom: 30px;
}

/* ============================================
   🔘 الأزرار
   ============================================ */
.menu-buttons {
    display: flex;
    flex-direction: column;
    gap: 15px;
    margin: 30px 0;
}

.btn-primary, .btn-secondary, .btn-danger, .btn-pause {
    padding: 18px 40px;
    border: none;
    border-radius: 50px;
    font-size: 1.2em;
    font-weight: bold;
    cursor: pointer;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
}

.btn-primary {
    background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
    color: white;
}

.btn-primary:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 25px rgba(102, 126, 234, 0.4);
}

.btn-secondary {
    background: var(--light-color);
    color: var(--primary-color);
}

.btn-secondary:hover {
    background: #d5d8dc;
    transform: translateY(-2px);
}

.btn-danger {
    background: var(--danger-color);
    color: white;
    padding: 12px 30px;
    font-size: 1em;
}

.btn-danger:hover {
    background: #c0392b;
    transform: translateY(-2px);
}

.btn-pause {
    background: rgba(255, 255, 255, 0.95);
    padding: 12px 18px;
    font-size: 1.8em;
    box-shadow: 0 3px 10px rgba(0, 0, 0, 0.3);
}

.btn-pause:hover {
    background: white;
    transform: scale(1.1);
}

kbd {
    background: #f4f4f4;
    border: 2px solid #ccc;
    border-radius: 5px;
    padding: 3px 8px;
    font-family: monospace;
    font-weight: bold;
    box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
}

/* ============================================
   📊 الإحصائيات
   ============================================ */
.stats-container {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 15px;
    margin-top: 40px;
}

.stat-box {
    background: linear-gradient(135deg, #f8f9fa, #e9ecef);
    padding: 20px;
    border-radius: 15px;
    display: flex;
    align-items: center;
    gap: 15px;
    box-shadow: 0 3px 10px rgba(0, 0, 0, 0.1);
    transition: transform 0.3s ease;
}

.stat-box:hover {
    transform: translateY(-5px);
    box-shadow: 0 5px 20px rgba(0, 0, 0, 0.15);
}

.stat-icon {
    font-size: 2.5em;
}

.stat-info {
    text-align: right;
}

.stat-label {
    font-size: 0.9em;
    color: #666;
    margin-bottom: 5px;
}

.stat-value {
    font-size: 1.8em;
    font-weight: bold;
    color: var(--primary-color);
}

/* ============================================
   📜 التعليمات
   ============================================ */
.instructions-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    margin: 30px 0;
}

.instruction-card {
    background: linear-gradient(135deg, #f8f9fa, #e9ecef);
    padding: 25px;
    border-radius: 15px;
    text-align: right;
    transition: transform 0.3s ease;
}

.instruction-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
}

.instruction-icon {
    font-size: 3em;
    margin-bottom: 15px;
}

.instruction-card h3 {
    font-size: 1.4em;
    color: var(--dark-color);
    margin-bottom: 15px;
}

.instruction-card ul {
    list-style: none;
    text-align: right;
}

.instruction-card li {
    padding: 8px 0;
    font-size: 1.05em;
    color: #555;
}

/* ============================================
   ⚙️ الإعدادات
   ============================================ */
.settings-content {
    margin: 30px 0;
}

.setting-item {
    background: #f8f9fa;
    padding: 20px;
    border-radius: 12px;
    margin: 15px 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
}

.setting-item label {
    font-size: 1.2em;
    font-weight: 600;
    color: var(--dark-color);
}

.setting-item input[type="range"] {
    width: 200px;
    height: 8px;
    border-radius: 5px;
    outline: none;
    -webkit-appearance: none;
    background: #ddd;
}

.setting-item input[type="range"]::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: var(--primary-color);
    cursor: pointer;
}

.setting-item input[type="checkbox"] {
    width: 50px;
    height: 25px;
    cursor: pointer;
}

/* ============================================
   🗺️ الخريطة
   ============================================ */
.map-container {
    background: rgba(255, 255, 255, 0.98);
    padding: 40px;
    border-radius: 25px;
    max-width: 1000px;
    width: 95%;
    max-height: 90vh;
    overflow-y: auto;
}

.map-title {
    text-align: center;
    font-size: 2.8em;
    color: var(--primary-color);
    margin-bottom: 40px;
}

.map-world {
    position: relative;
}

.map-path-container {
    display: flex;
    align-items: center;
    justify-content: space-around;
    flex-wrap: wrap;
    gap: 20px;
    margin: 40px 0;
}

.map-level {
    background: white;
    padding: 25px;
    border-radius: 20px;
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.2);
    cursor: pointer;
    transition: all 0.4s ease;
    text-align: center;
    min-width: 180px;
    position: relative;
    border: 3px solid transparent;
}

.map-level:hover {
    transform: scale(1.1) rotate(2deg);
    box-shadow: 0 12px 35px rgba(0, 0, 0, 0.3);
}

.map-level.locked {
    opacity: 0.4;
    cursor: not-allowed;
    filter: grayscale(100%);
}

.map-level.locked:hover {
    transform: none;
}

.map-level.completed {
    border-color: gold;
    background: linear-gradient(135deg, #fff9e6, #ffffff);
}

.level-badge {
    position: absolute;
    top: -15px;
    left: -15px;
    background: var(--primary-color);
    color: white;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
    font-size: 1.3em;
    box-shadow: 0 3px 10px rgba(0, 0, 0, 0.3);
}

.level-icon {
    font-size: 4em;
    margin: 15px 0;
}

.level-name {
    font-size: 1.2em;
    font-weight: bold;
    color: var(--dark-color);
    margin: 10px 0;
}

.level-stars {
    font-size: 1.5em;
    margin: 10px 0;
}

.level-coins {
    font-size: 1.1em;
    color: #666;
    margin-top: 8px;
}

.map-path {
    width: 80px;
    height: 6px;
    background: linear-gradient(90deg, var(--primary-color), var(--secondary-color));
    border-radius: 3px;
    box-shadow: 0 2px 5px rgba(0, 0, 0, 0.2);
}

.map-back-btn {
    display: block;
    margin: 30px auto 0;
    max-width: 300px;
}

/* ============================================
   🎮 شاشة اللعب
   ============================================ */
#gameScreen {
    position: relative;
    background: #87CEEB;
    padding: 0;
}

#gameCanvas {
    display: block;
    width: 100%;
    height: 100%;
    background: linear-gradient(to bottom, #87CEEB 0%, #E0F6FF 100%);
}

#particlesCanvas {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 1;
}

/* ============================================
   🎯 HUD - واجهة المعلومات
   ============================================ */
.hud {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding: 20px;
    background: linear-gradient(to bottom, rgba(0, 0, 0, 0.7), transparent);
    z-index: 10;
    gap: 20px;
}

.hud-left, .hud-center, .hud-right {
    display: flex;
    flex-direction: column;
    gap: 10px;
}

.hud-center {
    flex: 1;
    align-items: center;
}

/* ============================================
   ❤️ شريط الصحة
   ============================================ */
.health-container {
    display: flex;
    align-items: center;
    gap: 10px;
    background: rgba(0, 0, 0, 0.6);
    padding: 10px 15px;
    border-radius: 25px;
}

.health-icon {
    font-size: 2em;
    animation: heartbeat 1.5s ease infinite;
}

@keyframes heartbeat {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.1); }
}

.health-bar {
    width: 200px;
    height: 25px;
    background: rgba(255, 255, 255, 0.3);
    border-radius: 15px;
    overflow: hidden;
    position: relative;
    border: 2px solid rgba(255, 255, 255, 0.5);
}

.health-fill {
    height: 100%;
    width: 100%;
    background: linear-gradient(90deg, #e74c3c, #c0392b);
    border-radius: 15px;
    transition: width 0.3s ease;
    box-shadow: inset 0 2px 5px rgba(0, 0, 0, 0.3);
    position: relative;
}

.health-fill::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 50%;
    background: linear-gradient(to bottom, rgba(255, 255, 255, 0.3), transparent);
    border-radius: 15px 15px 0 0;
}

.health-text {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    color: white;
    font-weight: bold;
    font-size: 0.9em;
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.5);
}

/* ============================================
   💰 عداد العملات والنقاط
   ============================================ */
.coin-display, .score-display, .time-display {
    background: rgba(0, 0, 0, 0.6);
    padding: 10px 20px;
    border-radius: 20px;
    display: flex;
    align-items: center;
    gap: 10px;
    color: white;
    font-size: 1.3em;
    font-weight: bold;
}

.coin-icon, .score-icon, .time-icon {
    font-size: 1.5em;
}

.coin-count, .score-count, .time-count {
    text-shadow: 0 2px 5px rgba(0, 0, 0, 0.5);
}

/* ============================================
   📊 شريط التقدم
   ============================================ */
.level-title {
    color: white;
    font-size: 1.8em;
    text-shadow: 0 2px 5px rgba(0, 0, 0, 0.5);
    margin-bottom: 10px;
}

.progress-container {
    display: flex;
    align-items: center;
    gap: 15px;
    background: rgba(0, 0, 0, 0.6);
    padding: 10px 20px;
    border-radius: 25px;
}

.progress-bar {
    width: 300px;
    height: 20px;
    background: rgba(255, 255, 255, 0.3);
    border-radius: 10px;
    overflow: hidden;
    border: 2px solid rgba(255, 255, 255, 0.5);
}

.progress-fill {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, #2ecc71, #27ae60);
    border-radius: 10px;
    transition: width 0.3s ease;
    box-shadow: 0 0 10px rgba(46, 204, 113, 0.5);
}

.progress-text {
    color: white;
    font-weight: bold;
    font-size: 1.1em;
    text-shadow: 0 2px 5px rgba(0, 0, 0, 0.5);
    min-width: 50px;
    text-align: left;
}

/* ============================================
   📱 أزرار التحكم للموبايل
   ============================================ */
.mobile-controls {
    position: absolute;
    bottom: 30px;
    left: 50%;
    transform: translateX(-50%);
    display: none;
    gap: 30px;
    z-index: 10;
}

.control-btn {
    width: 80px;
    height: 80px;
    font-size: 2.5em;
    border: none;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.9);
    box-shadow: 0 5px 20px rgba(0, 0, 0, 0.4);
    cursor: pointer;
    transition: all 0.2s ease;
    display: flex;
    align-items: center;
    justify-content: center;
}

.control-btn:active {
    transform: scale(0.9);
    background: white;
    box-shadow: 0 3px 15px rgba(0, 0, 0, 0.5);
}

.control-jump {
    background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
    color: white;
}

/* ============================================
   ⏸️ شاشة الإيقاف المؤقت
   ============================================ */
.pause-stats {
    background: #f8f9fa;
    padding: 25px;
    border-radius: 15px;
    margin: 30px 0;
}

.pause-stats p {
    font-size: 1.4em;
    margin: 12px 0;
    color: var(--dark-color);
}

/* ============================================
   🏆 شاشة النتائج
   ============================================ */
.result-title {
    font-size: 3em;
    margin-bottom: 30px;
}

.stars-display {
    display: flex;
    justify-content: center;
    gap: 20px;
    margin: 30px 0;
}

.star-item {
    font-size: 4em;
    animation: starPop 0.5s ease forwards;
    opacity: 0;
}

.star-item:nth-child(1) { animation-delay: 0.2s; }
.star-item:nth-child(2) { animation-delay: 0.4s; }
.star-item:nth-child(3) { animation-delay: 0.6s; }

@keyframes starPop {
    0% {
        transform: scale(0) rotate(0deg);
        opacity: 0;
    }
    70% {
        transform: scale(1.2) rotate(180deg);
    }
    100% {
        transform: scale(1) rotate(360deg);
        opacity: 1;
    }
}

.result-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 15px;
    margin: 30px 0;
}

.result-stat {
    background: linear-gradient(135deg, #f8f9fa, #e9ecef);
    padding: 20px;
    border-radius: 15px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
}

.result-icon {
    font-size: 2.5em;
}

.result-info {
    text-align: center;
}

.result-label {
    font-size: 0.9em;
    color: #666;
    margin-bottom: 5px;
}

.result-value {
    font-size: 1.8em;
    font-weight: bold;
    color: var(--primary-color);
}

/* ============================================
   📱 Responsive Design
   ============================================ */
@media (max-width: 1024px) {
    .instructions-grid {
        grid-template-columns: 1fr;
    }
    
    .stats-container {
        grid-template-columns: 1fr;
    }
    
    .result-stats {
        grid-template-columns: 1fr;
    }
}

@media (max-width: 768px) {
    .mobile-controls {
        display: flex;
    }
    
    .game-title {
        font-size: 2.5em;
    }
    
    .animated-title {
        font-size: 2.2em;
    }
    
    h2 {
        font-size: 1.8em;
    }
    
    .menu-container {
        padding: 30px 20px;
    }
    
    .map-path-container {
        flex-direction: column;
    }
    
    .map-path {
        width: 6px;
        height: 50px;
    }
    
    .hud {
        flex-direction: column;
        gap: 10px;
        font-size: 0.85em;
    }
    
    .health-bar {
        width: 120px;
        height: 20px;
    }
    
    .progress-bar {
        width: 150px;
    }
    
    .control-btn {
        width: 70px;
        height: 70px;
        font-size: 2em;
    }
    
    .level-title {
        font-size: 1.3em;
    }
    
    .stars-display {
        gap: 10px;
    }
    
    .star-item {
        font-size: 3em;
    }
}

@media (max-width: 480px) {
    .loading-bar {
        width: 280px;
    }
    
    .btn-primary, .btn-secondary {
        font-size: 1em;
        padding: 15px 30px;
    }
    
    .instruction-card {
        padding: 15px;
    }
    
    .level-icon {
        font-size: 3em;
    }
}

/* ============================================
   🎭 تأثيرات إضافية
   ============================================ */
.menu-container {
    animation: float 6s ease-in-out infinite;
}

@keyframes float {
    0%, 100% {
        transform: translateY(0px);
    }
    50% {
        transform: translateY(-10px);
    }
}

/* Scrollbar تخصيص */
.menu-container::-webkit-scrollbar {
    width: 8px;
}

.menu-container::-webkit-scrollbar-track {
    background: #f1f1f1;
    border-radius: 10px;
}

.menu-container::-webkit-scrollbar-thumb {
    background: var(--primary-color);
    border-radius: 10px;
}

.menu-container::-webkit-scrollbar-thumb:hover {
    background: var(--secondary-color);
}

/* تأثير التوهج للعناصر المهمة */
.btn-primary {
    position: relative;
    overflow: hidden;
}

.btn-primary::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 0;
    height: 0;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.3);
    transform: translate(-50%, -50%);
    transition: width 0.6s, height 0.6s;
}

.btn-primary:hover::before {
    width: 300px;
    height: 300px;
}

/* تأثير النجوم المتلألئة */
@keyframes twinkle {
    0%, 100% {
        opacity: 1;
        transform: scale(1);
    }
    50% {
        opacity: 0.5;
        transform: scale(0.9);
    }
}

.level-stars span {
    display: inline-block;
    animation: twinkle 2s ease-in-out infinite;
