<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>🚀 مطاردة الكنوز في الفضاء</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Arial', sans-serif;
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
            overflow: hidden;
            height: 100vh;
            position: relative;
        }
        .stars { position: fixed; width: 100%; height: 100%; pointer-events: none; }
        .star { position: absolute; background: white; border-radius: 50%; animation: twinkle 3s infinite; }
        @keyframes twinkle { 0%, 100% { opacity: 0.3; } 50% { opacity: 1; } }
        .screen { position: fixed; top: 0; left: 0; width: 100%; height: 100%; display: none; justify-content: center; align-items: center; z-index: 10; }
        .screen.active { display: flex; }
        .menu-box { background: rgba(255, 255, 255, 0.95); padding: 50px; border-radius: 30px; box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5); text-align: center; animation: slideDown 0.5s ease; max-width: 90%; max-height: 90vh; overflow-y: auto; }
        @keyframes slideDown { from { transform: translateY(-100px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
        .game-title { font-size: 3.5em; background: linear-gradient(45deg, #667eea, #764ba2, #f093fb); -webkit-background-clip: text; -webkit-text-fill-color: transparent; margin-bottom: 10px; font-weight: bold; }
        .subtitle { color: #666; font-size: 1.3em; margin-bottom: 30px; }
        .btn { background: linear-gradient(135deg, #667eea, #764ba2); color: white; border: none; padding: 18px 45px; margin: 10px; font-size: 1.2em; border-radius: 50px; cursor: pointer; box-shadow: 0 5px 20px rgba(102, 126, 234, 0.4); transition: all 0.3s ease; font-weight: bold; }
        .btn:hover { transform: translateY(-3px); box-shadow: 0 8px 30px rgba(102, 126, 234, 0.6); }
        .btn-secondary { background: linear-gradient(135deg, #f093fb, #f5576c); }
        .stats-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 15px; margin-top: 30px; }
        .stat-card { background: linear-gradient(135deg, #667eea, #764ba2); color: white; padding: 20px; border-radius: 15px; box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2); }
        .stat-icon { font-size: 2.5em; margin-bottom: 10px; }
        .stat-value { font-size: 2em; font-weight: bold; }
        .stat-label { font-size: 0.9em; opacity: 0.9; }
        #gameCanvas { display: block; background: #0a0e27; box-shadow: 0 0 50px rgba(102, 126, 234, 0.3); }
        .game-hud { position: fixed; top: 20px; left: 20px; right: 20px; display: none; justify-content: space-between; z-index: 5; }
        .game-hud.active { display: flex; }
        .hud-item { background: rgba(0, 0, 0, 0.8); color: white; padding: 15px 25px; border-radius: 15px; font-size: 1.3em; font-weight: bold; box-shadow: 0 5px 20px rgba(0, 0, 0, 0.3); }
        .hud-icon { font-size: 1.5em; margin-left: 10px; }
        .mobile-controls { position: fixed; bottom: 30px; left: 50%; transform: translateX(-50%); display: none; gap: 20px; z-index: 5; }
        .control-btn { width: 80px; height: 80px; background: rgba(255, 255, 255, 0.9); border: none; border-radius: 50%; font-size: 2.5em; cursor: pointer; box-shadow: 0 5px 20px rgba(0, 0, 0, 0.3); transition: all 0.2s; }
        .control-btn:active { transform: scale(0.9); background: white; }
        .result-box { background: rgba(255, 255, 255, 0.95); padding: 50px; border-radius: 30px; text-align: center; max-width: 500px; }
        .result-title { font-size: 3em; margin-bottom: 20px; }
        .result-stats { background: #f8f9fa; padding: 30px; border-radius: 15px; margin: 20px 0; }
        .result-stat { font-size: 1.5em; margin: 10px 0; color: #333; }
        .shop-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; margin: 30px 0; }
        .shop-item { background: linear-gradient(135deg, #e0e7ff, #f0f4ff); padding: 25px; border-radius: 15px; border: 3px solid transparent; transition: all 0.3s; cursor: pointer; }
        .shop-item:hover { border-color: #667eea; transform: scale(1.05); }
        .shop-item.bought { opacity: 0.5; cursor: not-allowed; }
        .shop-icon { font-size: 3em; margin-bottom: 10px; }
        .shop-name { font-size: 1.3em; font-weight: bold; color: #333; margin-bottom: 10px; }
        .shop-price { background: #667eea; color: white; padding: 8px 20px; border-radius: 20px; display: inline-block; font-weight: bold; }
        @media (max-width: 768px) {
            .menu-box { padding: 30px 20px; width: 90%; }
            .game-title { font-size: 2.5em; }
            .stats-grid, .shop-grid { grid-template-columns: 1fr; }
            .mobile-controls { display: flex; }
        }
    </style>
</head>
<body>
    <div class="stars" id="starsContainer"></div>

    <!-- القائمة الرئيسية -->
    <div class="screen active" id="mainMenu">
        <div class="menu-box">
            <h1 class="game-title">🚀 مطاردة الكنوز</h1>
            <p class="subtitle">اجمع النجوم وتجنب الكويكبات!</p>
            <button class="btn" onclick="startGame()">🎮 ابدأ اللعب</button>
            <button class="btn btn-secondary" onclick="showShop()">🛒 المتجر</button>
            <button class="btn" onclick="showInstructions()">📖 التعليمات</button>
            
            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-icon">⭐</div>
                    <div class="stat-value" id="bestScore">0</div>
                    <div class="stat-label">أعلى نقاط</div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon">💎</div>
                    <div class="stat-value" id="totalGems">0</div>
                    <div class="stat-label">إجمالي الجواهر</div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon">🎯</div>
                    <div class="stat-value" id="gamesPlayed">0</div>
                    <div class="stat-label">عدد المرات</div>
                </div>
            </div>
        </div>
    </div>

    <!-- شاشة التعليمات -->
    <div class="screen" id="instructionsScreen">
        <div class="menu-box">
            <h2 style="color: #667eea; margin-bottom: 30px;">📖 كيف تلعب؟</h2>
            <div style="text-align: right; font-size: 1.2em; color: #333;">
                <p style="margin: 15px 0;">🎮 <strong>التحكم:</strong></p>
                <p style="margin: 10px 0;">• استخدم الأسهم أو أزرار اللمس للحركة</p>
                <p style="margin: 10px 0;">• تحرك يميناً ويساراً لجمع النجوم</p>
                
                <p style="margin: 20px 0;">⭐ <strong>الأهداف:</strong></p>
                <p style="margin: 10px 0;">• اجمع النجوم الصفراء (+10 نقاط)</p>
                <p style="margin: 10px 0;">• اجمع الجواهر الزرقاء (+1 جوهرة)</p>
                <p style="margin: 10px 0;">• تجنب الكويكبات الحمراء!</p>
                
                <p style="margin: 20px 0;">💎 <strong>المتجر:</strong></p>
                <p style="margin: 10px 0;">• استخدم الجواهر لشراء ترقيات</p>
                <p style="margin: 10px 0;">• سرعة أكبر، مغناطيس، درع واقي</p>
            </div>
            <button class="btn" onclick="showMainMenu()">رجوع</button>
        </div>
    </div>

    <!-- شاشة المتجر -->
    <div class="screen" id="shopScreen">
        <div class="menu-box" style="max-width: 700px;">
            <h2 style="color: #667eea; margin-bottom: 20px;">🛒 متجر الترقيات</h2>
            <div style="background: #667eea; color: white; padding: 15px; border-radius: 10px; margin-bottom: 20px;">
                <span style="font-size: 1.5em;">💎 الجواهر: <strong id="shopGems">0</strong></span>
            </div>
            
            <div class="shop-grid">
                <div class="shop-item" id="speedUpgrade" onclick="buyUpgrade('speed')">
                    <div class="shop-icon">⚡</div>
                    <div class="shop-name">سرعة فائقة</div>
                    <p style="color: #666; margin: 10px 0;">زيادة سرعة المركبة</p>
                    <div class="shop-price">💎 50</div>
                </div>
                
                <div class="shop-item" id="magnetUpgrade" onclick="buyUpgrade('magnet')">
                    <div class="shop-icon">🧲</div>
                    <div class="shop-name">مغناطيس النجوم</div>
                    <p style="color: #666; margin: 10px 0;">جذب النجوم تلقائياً</p>
                    <div class="shop-price">💎 100</div>
                </div>
                
                <div class="shop-item" id="shieldUpgrade" onclick="buyUpgrade('shield')">
                    <div class="shop-icon">🛡️</div>
                    <div class="shop-name">درع واقي</div>
                    <p style="color: #666; margin: 10px 0;">حماية من الاصطدام</p>
                    <div class="shop-price">💎 150</div>
                </div>
                
                <div class="shop-item" id="doubleUpgrade" onclick="buyUpgrade('double')">
                    <div class="shop-icon">✨</div>
                    <div class="shop-name">نقاط مضاعفة</div>
                    <p style="color: #666; margin: 10px 0;">ضعف النقاط</p>
                    <div class="shop-price">💎 200</div>
                </div>
            </div>
            
            <button class="btn" onclick="showMainMenu()">رجوع</button>
        </div>
    </div>

    <!-- شاشة اللعب -->
    <div class="screen" id="gameScreen">
        <canvas id="gameCanvas"></canvas>
    </div>

    <!-- واجهة اللعب -->
    <div class="game-hud" id="gameHUD">
        <div class="hud-item">
            <span class="hud-icon">⭐</span>
            <span id="scoreDisplay">0</span>
        </div>
        <div class="hud-item">
            <span class="hud-icon">💎</span>
            <span id="gemsDisplay">0</span>
        </div>
        <div class="hud-item">
            <span class="hud-icon">❤️</span>
            <span id="livesDisplay">3</span>
        </div>
    </div>

    <!-- أزرار التحكم للموبايل -->
    <div class="mobile-controls">
        <button class="control-btn" id="leftBtn">⬅️</button>
        <button class="control-btn" id="rightBtn">➡️</button>
    </div>

    <!-- شاشة النتيجة -->
    <div class="screen" id="resultScreen">
        <div class="result-box">
            <div class="result-title" id="resultTitle">🎉</div>
            <div class="result-stats">
                <div class="result-stat">⭐ النقاط: <strong id="finalScore">0</strong></div>
                <div class="result-stat">💎 الجواهر: <strong id="finalGems">0</strong></div>
                <div class="result-stat" id="newRecord" style="color: #f5576c; display: none;">🏆 رقم قياسي جديد! 🏆</div>
            </div>
            <button class="btn" onclick="startGame()">🔄 العب مرة أخرى</button>
            <button class="btn btn-secondary" onclick="showMainMenu()">🏠 القائمة الرئيسية</button>
        </div>
    </div>

    <script>
        const canvas = document.getElementById('gameCanvas');
        const ctx = canvas.getContext('2d');
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;

        let bestScore = parseInt(localStorage.getItem('bestScore')) || 0;
        let totalGems = parseInt(localStorage.getItem('totalGems')) || 0;
        let gamesPlayed = parseInt(localStorage.getItem('gamesPlayed')) || 0;
        let upgrades = JSON.parse(localStorage.getItem('upgrades')) || {speed: false, magnet: false, shield: false, double: false};

        let gameRunning = false, score = 0, gems = 0, lives = 3;
        let player = null, stars = [], asteroids = [], gemItems = [], particles = [], keys = {};

        function createBackgroundStars() {
            const container = document.getElementById('starsContainer');
            container.innerHTML = '';
            for (let i = 0; i < 100; i++) {
                const star = document.createElement('div');
                star.className = 'star';
                star.style.left = Math.random() * 100 + '%';
                star.style.top = Math.random() * 100 + '%';
                star.style.width = star.style.height = Math.random() * 3 + 'px';
                star.style.animationDelay = Math.random() * 3 + 's';
                container.appendChild(star);
            }
        }
        createBackgroundStars();

        function showScreen(screenId) {
            document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
            document.getElementById(screenId).classList.add('active');
        }

        function showMainMenu() {
            showScreen('mainMenu');
            document.getElementById('bestScore').textContent = bestScore;
            document.getElementById('totalGems').textContent = totalGems;
            document.getElementById('gamesPlayed').textContent = gamesPlayed;
        }

        function showInstructions() { showScreen('instructionsScreen'); }
        
        function showShop() {
            showScreen('shopScreen');
            document.getElementById('shopGems').textContent = totalGems;
            Object.keys(upgrades).forEach(key => {
                const item = document.getElementById(key + 'Upgrade');
                if (upgrades[key]) {
                    item.classList.add('bought');
                    item.querySelector('.shop-price').textContent = '✅ تم الشراء';
                }
            });
        }

        function buyUpgrade(type) {
            if (upgrades[type]) { alert('لقد اشتريت هذه الترقية مسبقاً!'); return; }
            const prices = {speed: 50, magnet: 100, shield: 150, double: 200};
            if (totalGems >= prices[type]) {
                totalGems -= prices[type];
                upgrades[type] = true;
                localStorage.setItem('totalGems', totalGems);
                localStorage.setItem('upgrades', JSON.stringify(upgrades));
                showShop();
                alert('✅ تم شراء الترقية بنجاح!');
            } else {
                alert('❌ ليس لديك جواهر كافية!');
            }
        }

        class Player {
            constructor() {
                this.width = 60; this.height = 80;
                this.x = canvas.width/2 - this.width/2;
                this.y = canvas.height - this.height - 50;
                this.speed = upgrades.speed ? 10 : 7;
                this.hasShield = false; this.shieldTime = 0;
            }
            draw() {
                if (this.hasShield) {
                    ctx.strokeStyle = 'rgba(102, 126, 234, 0.5)';
                    ctx.lineWidth = 5;
                    ctx.beginPath();
                    ctx.arc(this.x + this.width/2, this.y + this.height/2, 50, 0, Math.PI * 2);
                    ctx.stroke();
                }
                ctx.fillStyle = '#667eea';
                ctx.beginPath();
                ctx.moveTo(this.x + this.width/2, this.y);
                ctx.lineTo(this.x + this.width, this.y + this.height);
                ctx.lineTo(this.x, this.y + this.height);
                ctx.closePath();
                ctx.fill();
                ctx.fillStyle = '#4a5fc7';
                ctx.beginPath();
                ctx.arc(this.x + this.width/2, this.y + 30, 15, 0, Math.PI * 2);
                ctx.fill();
                ctx.fillStyle = '#f5576c';
                ctx.fillRect(this.x + 10, this.y + this.height, 15, 20 + Math.random() * 10);
                ctx.fillRect(this.x + this.width - 25, this.y + this.height, 15, 20 + Math.random() * 10);
            }
            update() {
                if (keys['ArrowLeft'] || keys['a']) this.x -= this.speed;
                if (keys['ArrowRight'] || keys['d']) this.x += this.speed;
                if (this.x < 0) this.x = 0;
                if (this.x > canvas.width - this.width) this.x = canvas.width - this.width;
                if (this.hasShield) {
                    this.shieldTime--;
                    if (this.shieldTime <= 0) this.hasShield = false;
                }
            }
            activateShield() {
                if (upgrades.shield) { this.hasShield = true; this.shieldTime = 180; }
            }
        }

        class Star {
            constructor() {
                this.width = 30; this.height = 30;
                this.x = Math.random() * (canvas.width - this.width);
                this.y = -this.height;
                this.speed = 3 + Math.random() * 2;
                this.rotation = 0;
            }
            draw() {
                ctx.save();
                ctx.translate(this.x + this.width/2, this.y + this.height/2);
                ctx.rotate(this.rotation);
                ctx.fillStyle = '#ffd700';
                ctx.beginPath();
                for (let i = 0; i < 5; i++) {
                    const angle = (Math.PI * 2 * i) / 5 - Math.PI / 2;
                    const x = Math.cos(angle) * 15, y = Math.sin(angle) * 15;
                    if (i === 0) ctx.moveTo(x, y);
                    else ctx.lineTo(x, y);
                    const angle2 = angle + Math.PI / 5;
                    const x2 = Math.cos(angle2) * 7, y2 = Math.sin(angle2) * 7;
                    ctx.lineTo(x2, y2);
                }
                ctx.closePath();
                ctx.fill();
                ctx.restore();
                this.rotation += 0.05;
            }
            update() { this.y += this.speed; }
        }

        class Gem {
            constructor() {
                this.width = 25; this.height = 25;
                this.x = Math.random() * (canvas.width - this.width);
                this.y = -this.height;
                this.speed = 2 + Math.random() * 1.5;
                this.rotation = 0;
            }
            draw() {
                ctx.save();
                ctx.translate(this.x + this.width/2, this.y + this.height/2);
                ctx.rotate(this.rotation);
                ctx.fillStyle = '#4facfe';
                ctx.beginPath();
                ctx.moveTo(0, -12);
                ctx.lineTo(8, -4); ctx.lineTo(8, 4);
                ctx.lineTo(0, 12); ctx.lineTo(-8, 4); ctx.lineTo(-8, -4);
                ctx.closePath();
                ctx.fill();
                ctx.restore();
                this.rotation += 0.08;
            }
            update() { this.y += this.speed; }
        }

        class Asteroid {
            constructor() {
                this.width = 40 + Math.random() * 30;
                this.height = this.width;
                this.x = Math.random() * (canvas.width - this.width);
                this.y = -this.height;
                this.speed = 4 + Math.random() * 3;
                this.rotation = 0;
            }
            draw() {
                ctx.save();
                ctx.translate(this.x + this.width/2, this.y + this.height/2);
                ctx.rotate(this.rotation);
                ctx.fillStyle = '#e74c3c';
                ctx.beginPath();
                ctx.arc(0, 0, this.width/2, 0, Math.PI * 2);
                ctx.fill();
                ctx.fillStyle = '#c0392b';
                ctx.beginPath();
                ctx.arc(-5, -5, 5, 0, Math.PI * 2);
                ctx.arc(7, 3, 4, 0, Math.PI * 2);
                ctx.arc(-3, 8, 3, 0, Math.PI * 2);
                ctx.fill();
                ctx.restore();
                this.rotation += 0.03;
            }
            update() { this.y += this.speed; }
        }

        class Particle {
            constructor(x, y, color) {
                this.x = x; this.y = y;
                this.vx = (Math.random() - 0.5) * 5;
                this.vy = (Math.random() - 0.5) * 5;
                this.life = 1; this.color = color;
                this.size = Math.random() * 5 + 3;
            }
            draw() {
                ctx.save();
                ctx.globalAlpha = this.life;
                ctx.fillStyle = this.color;
                ctx.beginPath();
                ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
                ctx.fill();
                ctx.restore();
            }
            update() {
                this.x += this.vx; this.y += this.vy;
                this.life -= 0.02;
            }
        }

        function startGame() {
            showScreen('gameScreen');
            document.getElementById('gameHUD').classList.add('active');
            gameRunning = true; score = 0; gems = 0; lives = 3;
            stars = []; asteroids = []; gemItems = []; particles = [];
            player = new Player();
            updateHUD();
            gameLoop();
        }

        let lastSpawn = 0;
        function gameLoop() {
            if (!gameRunning) return;
            ctx.fillStyle = '#0a0e27';
            ctx.fillRect(0, 0, canvas.width, canvas.height);
            ctx.fillStyle = 'white';
            for (let i = 0; i < 50; i++) {
                const x = (Date.now() * 0.01 + i * 50) % canvas.width;
                const y = (i * 123) % canvas.height;
                ctx.fillRect(x, y, 2, 2);
            }
            player.update(); player.draw();
            if (Date.now() - lastSpawn > 1000) {
                if (Math.random() < 0.7) stars.push(new Star());
                if (Math.random() < 0.3) asteroids.push(new Asteroid());
                if (Math.random() < 0.2) gemItems.push(new Gem());
                lastSpawn = Date.now();
            }
            stars = stars.filter(star => {
                star.update(); star.draw();
                if (checkCollision(player, star)) {
                    score += upgrades.double ? 20 : 10;
                    createParticles(star.x, star.y, '#ffd700');
                    updateHUD();
                    return false;
                }
                if (upgrades.magnet) {
                    const dx = player.x + player.width/2 - star.x;
                    const dy = player.y + player.height/2 - star.y;
                    const dist = Math.sqrt(dx*dx + dy*dy);
                    if (dist < 150) { star.x += dx * 0.1; star.y += dy * 0.1; }
                }
                return star.y < canvas.height;
            });
            gemItems = gemItems.filter(gem => {
                gem.update(); gem.draw();
                if (checkCollision(player, gem)) {
                    gems++;
                    createParticles(gem.x, gem.y, '#4facfe');
                    updateHUD();
                    return false;
                }
                if (upgrades.magnet) {
                    const dx = player.x + player.width/2 - gem.x;
                    const dy = player.y + player.height/2 - gem.y;
                    const dist = Math.sqrt(dx*dx + dy*dy);
                    if (dist < 150) { gem.x += dx * 0.1; gem.y += dy * 0.1; }
                }
                return gem.y < canvas.height;
            });
            asteroids = asteroids.filter(asteroid => {
                asteroid.update(); asteroid.draw();
                if (checkCollision(player, asteroid)) {
                    if (player.hasShield) {
                        player.hasShield = false;
                        createParticles(asteroid.x, asteroid.y, '#667eea');
                        return false;
                    } else {
                        lives--;
                        createParticles(asteroid.x, asteroid.y, '#e74c3c');
                        updateHUD();
                        if (upgrades.shield && lives > 0) player.activateShield();
                        if (lives <= 0) endGame();
                        return false;
                    }
                }
                return asteroid.y < canvas.height;
            });
            particles = particles.filter(p => { p.update(); p.draw(); return p.life > 0; });
            requestAnimationFrame(gameLoop);
        }

        function createParticles(x, y, color) {
            for (let i = 0; i < 15; i++) particles.push(new Particle(x, y, color));
        }

        function checkCollision(obj1, obj2) {
            return obj1.x < obj2.x + obj2.width && obj1.x + obj1.width > obj2.x &&
                   obj1.y < obj2.y + obj2.height && obj1.y + obj1.height > obj2.y;
        }

        function updateHUD() {
            document.getElementById('scoreDisplay').textContent = score;
            document.getElementById('gemsDisplay').textContent = gems;
            document.getElementById('livesDisplay').textContent = lives;
        }

        function endGame() {
            gameRunning = false;
            document.getElementById('gameHUD').classList.remove('active');
            totalGems += gems; gamesPlayed++;
            const newRecord = score > bestScore;
            if (newRecord) bestScore = score;
            localStorage.setItem('bestScore', bestScore);
            localStorage.setItem('totalGems', totalGems);
            localStorage.setItem('gamesPlayed', gamesPlayed);
            document.getElementById('resultTitle').textContent = lives <= 0 ? '💔 انتهت اللعبة!' : '🎉 رائع!';
            document.getElementById('finalScore').textContent = score;
            document.getElementById('finalGems').textContent = gems;
            document.getElementById('newRecord').style.display = newRecord ? 'block' : 'none';
            showScreen('resultScreen');
        }

        document.addEventListener('keydown', (e) => { keys[e.key] = true; });
        document.addEventListener('keyup', (e) => { keys[e.key] = false; });
        document.getElementById('leftBtn').addEventListener('touchstart', () => { keys['ArrowLeft'] = true; });
        document.getElementById('leftBtn').addEventListener('touchend', () => { keys['ArrowLeft'] = false; });
        document.getElementById('rightBtn').addEventListener('touchstart', () => { keys['ArrowRight'] = true; });
        document.getElementById('rightBtn').addEventListener('touchend', () => { keys['ArrowRight'] = false; });
        
        window.addEventListener('load', () => { showMainMenu(); });
        window.addEventListener('resize', () => { canvas.width = window.innerWidth; canvas.height = window.innerHeight; });
    </script>
</body>
</html>
